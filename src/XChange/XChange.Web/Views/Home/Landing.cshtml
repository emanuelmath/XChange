@*
    Vista parcial de Inicio o Landig para el proyecto XChange
*@
@{
    ViewData["Title"] = "Bienvenido";
    Layout = "~/Views/Shared/_LayoutPublic.cshtml";
}

<main>

    <!-- HERO -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">

                <!-- Texto -->
                <div class="col-12 col-lg-6 mb-4 mb-lg-0">
                    <h1 class="fw-bold mb-3">
                        Gestiona tu dinero con <span class="text-primary">seguridad y control</span>
                    </h1>

                    <p class="text-muted mb-4">
                        XChange es una billetera digital diseñada para ofrecerte transacciones rápidas,
                        protección avanzada y una experiencia moderna para administrar tus finanzas.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary px-4">
                            <i class="fa-solid fa-user-plus me-2"></i>Crear cuenta
                        </a>

                        <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary px-4">
                            <i class="fa-solid fa-right-to-bracket me-2"></i>Iniciar sesión
                        </a>
                    </div>
                </div>

                <!-- Imagen -->
                <div class="col-12 col-lg-6 text-center">
                    <img src="~/images/hero-wallet.png" class="img-fluid" alt="Wallet illustration">
                    </div>

                </div>
            </div>
        </section>

        <!-- features -->
        <section class="py-5">
            <div class="container text-center">

                <h2 class="fw-bold mb-3">¿Por qué elegir XChange?</h2>
                <p class="text-muted mb-5">
                    Diseñamos cada detalle pensando en seguridad, eficiencia y facilidad de uso.
                </p>

                <div class="row g-4">

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 shadow-sm h-100 p-4">
                            <i class="fa-solid fa-shield-halved text-primary fs-2 mb-3"></i>
                            <h5 class="fw-semibold">Seguridad avanzada</h5>
                            <p class="text-muted small">
                                Protección en múltiples capas para mantener tus datos y dinero seguros.
                            </p>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 shadow-sm h-100 p-4">
                            <i class="fa-solid fa-bolt text-primary fs-2 mb-3"></i>
                            <h5 class="fw-semibold">Transacciones rápidas</h5>
                            <p class="text-muted small">
                                Envía y recibe dinero de forma instantánea sin complicaciones.
                            </p>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 shadow-sm h-100 p-4">
                            <i class="fa-solid fa-mobile-screen-button text-primary fs-2 mb-3"></i>
                            <h5 class="fw-semibold">Acceso desde cualquier lugar</h5>
                            <p class="text-muted small">
                                Gestiona tu billetera desde cualquier dispositivo de forma segura.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- cómo trabaja -->
        <section class="py-5 bg-light">
            <div class="container text-center">

                <h2 class="fw-bold mb-3">¿Cómo funciona?</h2>
                <p class="text-muted mb-5">
                    Comienza en minutos y toma el control de tus finanzas digitales.
                </p>

                <div class="row g-4">

                    <div class="col-12 col-md-4">
                        <div class="p-4">
                            <i class="fa-solid fa-user-plus text-primary fs-2 mb-3"></i>
                            <h6 class="fw-semibold">1. Regístrate</h6>
                            <p class="text-muted small">
                                Crea tu cuenta en pocos pasos.
                            </p>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-4">
                            <i class="fa-solid fa-shield text-primary fs-2 mb-3"></i>
                            <h6 class="fw-semibold">2. Verifica tu identidad</h6>
                            <p class="text-muted small">
                                Activa la seguridad y protege tu cuenta.
                            </p>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-4">
                            <i class="fa-solid fa-money-bill-transfer text-primary fs-2 mb-3"></i>
                            <h6 class="fw-semibold">3. Opera libremente</h6>
                            <p class="text-muted small">
                                Realiza transacciones de forma rápida y segura.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- CTA final -->
        <section class="py-5">
            <div class="container text-center">

                <div class="card border-0 shadow-sm p-5">

                    <h3 class="fw-bold mb-3">
                        Empieza hoy con XChange
                    </h3>

                    <p class="text-muted mb-4">
                        Únete a una plataforma diseñada para brindarte control total sobre tu dinero.
                    </p>

                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary px-4">
                            Crear cuenta
                        </a>
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary px-4">
                            Iniciar sesión
                        </a>
                    </div>

                </div>

            </div>
        </section>

    </main>