@*
    Vista de registro para la aplicación XChange
*@

@using XChange.Web.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Registro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/fontawesome/css/all.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />

</head>
<body>

    <!-- Sección de encabezado de página -->
    <header class="bg-white shadow-sm py-3">
        <div class="container d-flex justify-content-between align-items-center">
            <h1 class="h4 mb-0 fw-bolder text-primary tracking-tight">XChange</h1>
        </div>
    </header>

    <!-- Contenido de la página -->
    <main class="flex-grow-1 d-flex align-items-center py-5">
        <div class="container">
            <div class="row justify-content-center">
                <article class="col-12 col-xl-10">
                    <div class="card border-0 shadow-lg overflow-hidden rounded-4">
                        <div class="row g-0">

                            <aside class="col-lg-5 d-none d-lg-flex bg-primary text-white p-5 flex-column justify-content-center position-relative">
                                <div class="z-1 pe-3">
                                    <h2 class="display-6 fw-bold mb-4">Únete a XChange</h2>
                                    <p class="lead mb-5 opacity-75">
                                        Crea tu cuenta y comienza a gestionar tu dinero de forma rápida, segura y sencilla.
                                    </p>

                                    <ul class="list-unstyled fs-5 mb-0">
                                        <li class="mb-3 d-flex align-items-center">
                                            <i class="fa-solid fa-bolt me-3 fs-4"></i> Registro rápido
                                        </li>
                                        <li class="mb-3 d-flex align-items-center">
                                            <i class="fa-solid fa-shield-halved me-3 fs-4"></i> Seguridad integrada
                                        </li>
                                        <li class="d-flex align-items-center">
                                            <i class="fa-solid fa-wallet me-3 fs-4"></i> Control total
                                        </li>
                                    </ul>
                                </div>
                            </aside>

                            <section class="col-12 col-lg-7 p-4 p-md-5 bg-white">
                                <div class="px-xl-4 py-xl-3">
                                
                                    <header class="mb-5">
                                        <h3 class="fw-bold mb-1">Crear cuenta</h3>
                                        <p class="text-muted mb-0">Completa los siguientes datos para comenzar</p>
                                    </header>

                                    <form id="registerForm">
                                        @Html.AntiForgeryToken()

                                        <div class="row g-3 mb-3">
                                            <div class="col-md-6">
                                                <div class="form-floating">
                                                    <input asp-for="FirstName" class="form-control" placeholder="Nombre" required>
                                                        <label asp-for="FirstName" class="text-muted">Nombre</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-floating">
                                                        <input asp-for="LastName" class="form-control" placeholder="Apellido" required>
                                                            <label asp-for="LastName" class="text-muted">Apellido</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="form-floating mb-3">
                                                    <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" required>
                                                        <label asp-for="Email" class="text-muted">Correo electrónico</label>
                                                    </div>

                                                    <div class="row g-3 mb-4">
                                                        <div class="col-md-6">
                                                            <div class="form-floating">
                                                                <input asp-for="Password" type="password" class="form-control" placeholder="•••••••" required>
                                                                    <label asp-for="Password" class="text-muted">Contraseña</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <div class="form-floating">
                                                                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="•••••••" required>
                                                                        <label asp-for="ConfirmPassword" class="text-muted">Confirmar contraseña</label>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="form-check mb-4">
                                                                <input class="form-check-input" type="checkbox" id="terminos" name="terminos" required>
                                                                <label class="form-check-label text-muted small" for="terminos">
                                                                    Acepto los <a href="#" class="text-decoration-none fw-semibold">
                                                                    Términos y Condiciones
                                                                </a> y la <a href="#" class="text-decoration-none fw-semibold">
                                                                Política de Privacidad
                                                            </a>
                                                        </label>
                                                    </div>

                                                    <button type="submit" class="btn btn-primary btn-lg w-100 mb-4 fw-semibold shadow-sm">
                                                        Crear cuenta
                                                    </button>

                                                    <div class="position-relative mb-4 text-center">
                                                        <hr class="text-muted border-secondary opacity-25">
                                                        <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">o</span>
                                                    </div>

                                                    <footer class="text-center mt-auto">
                                                        <p class="text-muted small mb-0">
                                                            ¿Ya tienes cuenta? <a asp-action="Login" asp-controller="Auth" class="text-decoration-none fw-semibold">Inicia sesión</a>
                                                        </p>
                                                    </footer>
                                                </form>

                                                <form asp-controller="Auth" asp-action="LoginOrRegisterWithGoogle" method="post">
                                                    <button type="submit" class="btn btn-outline-dark w-100 mb-4 py-2 fw-semibold d-flex align-items-center justify-content-center">
                                                        <i class="fa-brands fa-google me-2"></i> Registrarse con Google
                                                    </button>
                                                </form>
                        </div>
                    </section>
                </div>
            </div>
        </article>
    </div>
</div>
</main>

<!-- Sección de pie de página -->
<footer class="bg-white border-top py-4 mt-auto">
    <div class="container text-center">
        <small class="text-muted fw-medium">&copy; @DateTime.Now.Year XChange. Todos los derechos reservados.</small>
    </div>
</footer>

<!-- Sección de scripts -->
<script src="~/js/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="~/js/ajax-scripts.js" asp-append-version="true"></script>
<script src="~/js/bootstrap.bundle.min.js"></script>
<script src="~/js/toast-script.js" asp-append-version="true"></script>

</body>
</html>