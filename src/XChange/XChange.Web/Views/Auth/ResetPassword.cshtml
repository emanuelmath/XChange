@using XChange.Web.ViewModels;
@model ResetPasswordViewModel;

@*
    Vista parcial para resetear la contraseña de la cuenta del usuario en el módulo Auth.
*@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asignar nueva contraseña</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/fontawesome/css/all.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/toast-style.css" asp-append-version="true" />
</head>
<body>
    
    
    <div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
        <div class="row w-100 justify-content-center">

            <!-- Card general -->
            <div class="col-12 col-lg-10 col-xl-8">
                <div class="card border-0 shadow rounded-4 overflow-hidden">
                    <div class="row g-0">

                        <!-- Banner lateral -->
                        <div class="col-lg-5 d-none d-lg-flex flex-column justify-content-center bg-primary text-white p-5">

                            <h2 class="mb-4 fw-bold">Restablecer contraseña</h2>

                            <p class="mb-4">
                                Completa los siguientes pasos para asegurar tu cuenta y establecer una nueva contraseña.
                            </p>

                            <ul class="list-unstyled">
                                <li class="mb-3">
                                    <i class="fa-solid fa-envelope me-2"></i>
                                    Ingresa tu correo registrado
                                </li>
                                <li class="mb-3">
                                    <i class="fa-solid fa-key me-2"></i>
                                    Introduce el código enviado a tu correo
                                </li>
                                <li class="mb-3">
                                    <i class="fa-solid fa-lock me-2"></i>
                                    Define una nueva contraseña segura
                                </li>
                            </ul>

                            <div class="mt-4">
                                <small>
                                    Este proceso ayuda a proteger tu cuenta ante accesos no autorizados.
                                </small>
                            </div>

                        </div>

                        <!-- Formulario -->
                        <div class="col-12 col-lg-7 bg-white d-flex align-items-center p-4 p-lg-5">
                            <div class="w-100">

                                <h4 class="mb-3 text-center fw-bold">Nueva contraseña</h4>

                                <p class="text-muted text-center mb-4">
                                    Ingresa los datos solicitados para completar el cambio de contraseña.
                                </p>

                                <form id="resetPasswordForm">
                                    @Html.AntiForgeryToken()

                                    <!-- Correo -->
                                    <div class="form-floating mb-3">
                                        <input asp-for="Email" type="email" class="form-control" placeholder="correo@ejemplo.com" required>
                                            <label asp-for="Email" class="text-muted">Correo electrónico</label>
                                    </div>

                                    <!-- Código -->
                                    <div class="form-floating mb-3">
                                        <input asp-for="Token" type="text" class="form-control text-center" placeholder="Código" required>
                                            <label asp-for="Token" class="text-muted">Código de verificación</label>
                                    </div>

                                    <!-- Nueva contraseña -->
                                    <div class="form-floating mb-3">
                                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="•••••••" required>
                                            <label asp-for="NewPassword" class="text-muted">Nueva contraseña</label>
                                    </div>

                                    <!-- Mostrar contraseña -->
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="checkbox" id="showNewPassword">
                                        <label class="form-check-label" for="showNewPassword">
                                            Mostrar contraseña
                                        </label>
                                    </div>

                                    <!-- Autorización -->
                                    <div class="form-check mb-4">
                                        <input class="form-check-input" type="checkbox" id="confirmChange" required>
                                        <label class="form-check-label" for="confirmChange">
                                            Autorizo el cambio de contraseña y confirmo que soy el propietario de esta cuenta
                                        </label>
                                    </div>

                                    <!-- Botones -->
                                    <div class="d-flex gap-2">

                                        <a asp-action="Login" asp-controller="Auth"
                                               class="btn btn-outline-danger w-50">
                                            Cancelar
                                        </a>

                                        <button type="submit" class="btn btn-primary w-50">
                                            Confirmar
                                        </button>

                                    </div>

                                </form>

                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
    

    <!-- Footer -->
    <footer class="bg-white border-top py-4 mt-auto">
        <div class="container text-center">
            <small class="text-muted fw-medium">&copy; @DateTime.Now.Year XChange. Todos los derechos reservados.</small>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/js/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/ajax/auth-ajax-scripts.js" asp-append-version="true"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/toast-script.js"></script>
    
</body>
</html>
