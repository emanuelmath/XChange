@*
    Vista parcial de recuperación de contraseña para el módulo Auth.
*@
@{
    ViewData["Title"] = "Recuperación de contraseña";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
    <div class="row w-100 justify-content-center">

        <!-- Card general -->
        <div class="col-12 col-lg-10 col-xl-8">
            <div class="card border-0 shadow rounded-4 overflow-hidden">
                <div class="row g-0">

                    <!-- Banner lateral -->
                    <div class="col-lg-5 d-none d-lg-flex flex-column justify-content-center bg-primary text-white p-5">

                        <h2 class="mb-4 fw-bold">Recuperar acceso</h2>

                        <p class="mb-4">
                            Ingresa tu correo electrónico para enviarte instrucciones de recuperación.
                        </p>

                        <ul class="list-unstyled">
                            <li class="mb-3">
                                <i class="fa-solid fa-envelope me-2"></i>
                                Recibirás un código de seguridad
                            </li>
                            <li class="mb-3">
                                <i class="fa-solid fa-shield-halved me-2"></i>
                                Introdúcelo y luego se reasignará tu contraseña
                            </li>
                            <li class="mb-3">
                                <i class="fa-solid fa-lock me-2"></i>
                                Evita compartir tus credenciales
                            </li>
                        </ul>

                    </div>

                    <!-- Formulario -->
                    <div class="col-12 col-lg-7 bg-white d-flex align-items-center p-4 p-lg-5">
                        <div class="w-100">

                            <h4 class="mb-3 text-center fw-bold">Recuperar contraseña</h4>

                            <p class="text-muted text-center mb-4">
                                Ingresa un correo válido asociado a tu cuenta.
                                No utilices correos de terceros.
                            </p>

                            <form id="forgotPasswordForm">
                                @Html.AntiForgeryToken()

                                <!-- Correo -->
                                <div class="form-floating mb-4">
                                    <input type="email" class="form-control" placeholder="ejemplo@correo.com" required>
                                    <label class="text-muted">Correo electrónico</label>
                                </div>

                                <!-- Botón -->
                                <div class="d-grid mb-3">
                                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#confirmModal">
                                        Confirmar
                                    </button>
                                </div>

                            </form>

                            <!-- Volver -->
                            <div class="text-center">
                                <small>
                                    <a asp-action="Login" asp-controller="Auth" class="text-decoration-none fw-semibold">
                                        Volver a inicio de sesión
                                    </a>
                                </small>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Confirmar acción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <p class="mb-0">
                    ¿Estás seguro de que deseas continuar con la recuperación de contraseña?
                </p>
            </div>

            <div class="modal-footer border-0">

                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="submit" form="forgotPasswordForm" class="btn btn-primary">
                    Confirmar
                </button>

            </div>

        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/ajax/auth-ajax-scripts.js" asp-append-version="true"></script>
}

@section Styles
{
    <link rel="stylesheet" href="~/css/auth/forgotpassword.css" asp-append-version="true" />
}
