@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Estado de cuenta";
    Layout = "~/Views/Shared/_LayoutPrivate.cshtml";
}

<main>
    <header class="bg-primary bg-fintech pt-5 pb-5 fintech-hero">
        <div class="container text-white">
            <div class="row align-items-center mb-4">
                <div class="col-12 col-md-6 text-center text-md-start mb-4 mb-md-0">
                    <p class="opacity-75 mb-1 small text-uppercase fw-bold">Bienvenido de nuevo 👋</p>
                    <h2 class="fw-bold mb-0">Mi Billetera XChange</h2>
                </div>
                <div class="col-12 col-md-6 text-center text-md-end">
                    <p class="opacity-75 mb-1 small text-uppercase">Saldo Disponible</p>
                    <h1 class="display-4 fw-bold mb-3">$0.00</h1>
                    <div class="d-flex justify-content-center justify-content-md-end gap-2">
                        <span class="badge bg-white text-dark rounded-pill px-3 py-2">
                            <i class="fa-solid fa-arrow-down text-success me-1"></i> $0.00
                        </span>
                        <span class="badge bg-white text-dark rounded-pill px-3 py-2">
                            <i class="fa-solid fa-arrow-up text-danger me-1"></i> $0.00
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <section class="row justify-content-center floating-card mb-4">
            <div class="col-12">
                <div class="card border-0 shadow card-fintech">
                    <div class="card-body py-4">
                        <div class="row text-center g-3">
                            <div class="col-4 border-end">
                                <a href="#" class="text-decoration-none text-dark d-block">
                                    <div class="bg-light rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-paper-plane text-primary fs-4"></i>
                                    </div>
                                    <span class="small fw-bold">Enviar</span>
                                </a>
                            </div>
                            <div class="col-4 border-end">
                                <a href="#" class="text-decoration-none text-dark d-block">
                                    <div class="bg-light rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-qrcode text-primary fs-4"></i>
                                    </div>
                                    <span class="small fw-bold">Recibir</span>
                                </a>
                            </div>
                            <div class="col-4">
                                <a asp-controller="User" asp-action="Wallet" class="text-decoration-none text-dark d-block">
                                    <div class="bg-light rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-plus text-primary fs-4"></i>
                                    </div>
                                    <span class="small fw-bold">Cargar</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="row g-4 pb-5">
            <div class="col-12 col-lg-8">
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-4">
                        <a asp-controller="User" asp-action="Wallet" class="card h-100 border-0 shadow-sm card-fintech text-decoration-none border-start border-4 border-info">
                            <div class="card-body">
                                <i class="fa-solid fa-vault text-info mb-2 fs-4"></i>
                                <h6 class="fw-bold text-dark mb-0">Mi Wallet</h6>
                                <p class="text-muted small mb-0">Divisas</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-6 col-md-4">
                        <a asp-controller="User" asp-action="Transactions" class="card h-100 border-0 shadow-sm card-fintech text-decoration-none border-start border-4 border-primary">
                            <div class="card-body">
                                <i class="fa-solid fa-list-check text-primary mb-2 fs-4"></i>
                                <h6 class="fw-bold text-dark mb-0">Historial</h6>
                                <p class="text-muted small mb-0">Actividad</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-12 col-md-4">
                        <a asp-controller="User" asp-action="Settings" class="card h-100 border-0 shadow-sm card-fintech text-decoration-none border-start border-4 border-success">
                            <div class="card-body">
                                <i class="fa-solid fa-user-shield text-success mb-2 fs-4"></i>
                                <h6 class="fw-bold text-dark mb-0">Seguridad</h6>
                                <p class="text-muted small mb-0">MFA y Perfil</p>
                            </div>
                        </a>
                    </div>
                </div>

                <section class="card border-0 shadow-sm card-fintech">
                    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between">
                        <h5 class="fw-bold mb-0">Movimientos recientes</h5>
                        <i class="fa-solid fa-ellipsis-h text-muted"></i>
                    </div>
                    <div class="card-body p-5 text-center">
                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                            <i class="fa-solid fa-receipt text-muted fs-2"></i>
                        </div>
                        <h6 class="fw-bold">No hay transacciones aún</h6>
                        <p class="text-muted small">Tus pagos y transferencias aparecerán listados aquí.</p>
                    </div>
                </section>
            </div>

            <div class="col-12 col-lg-4">
                <section class="card bg-dark bg-fintech border-0 shadow-lg mb-4 text-white overflow-hidden" style="border-radius: 1.25rem;">
                    <div class="card-body p-4 position-relative">
                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <i class="fa-brands fa-cc-visa display-6"></i>
                            <i class="fa-solid fa-wifi fs-4 opacity-50"></i>
                        </div>
                        <h5 class="fw-bold mb-4" style="letter-spacing: 2px;">**** **** **** 8842</h5>
                        <div class="d-flex justify-content-between small opacity-75">
                            <span>USUARIO XCHANGE</span>
                            <span>12/28</span>
                        </div>
                    </div>
                </section>

                <section class="card border-0 shadow-sm card-fintech mb-4">
                    <div class="card-body p-3 text-center">
                        <p class="small text-muted fw-bold text-uppercase mb-3" style="font-size: 0.65rem;">Soporte Multired</p>
                        <div class="d-flex justify-content-around text-muted opacity-50">
                            <i class="fa-brands fa-cc-mastercard fs-3"></i>
                            <i class="fa-brands fa-paypal fs-3"></i>
                            <i class="fa-brands fa-apple-pay fs-2"></i>
                            <i class="fa-brands fa-google-pay fs-2"></i>
                        </div>
                    </div>
                </section>

                <section class="card border-0 shadow-sm card-fintech bg-light">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fa-solid fa-shield-halved text-warning fs-3 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Seguridad</h6>
                                <span class="badge bg-warning text-dark small">Nivel 2</span>
                            </div>
                        </div>
                        <div class="progress mb-2" style="height: 6px;">
                            <div class="progress-bar bg-warning" style="width: 65%"></div>
                        </div>
                        <p class="text-muted" style="font-size: 0.75rem;">Verifica tu identidad para el Nivel 3.</p>
                    </div>
                </section>
            </div>
        </div>
    </div>
</main>

@section Scripts
{
    <script src="~/js/ajax/user-ajax-scripts.js" asp-append-version="true"></script>
}

@section Styles
{
    <link rel="stylesheet" href="~/css/user/dashboard.css" />
}