@*
    Vista parcial de configuración del usuario.
*@
@{
    ViewData["Tittle"] = "Configuración de usuario";
    Layout = "~/Views/Shared/_LayoutPrivate.cshtml";
}

<main>

    <!-- HERO / HEADER -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">

                <div class="col-12 col-lg-6">
                    <h2 class="fw-bold mb-3">
                        Configura tu cuenta y <span class="text-primary">protege tu acceso</span>
                    </h2>

                    <p class="text-muted mb-4">
                        Administra tu información personal, preferencias y seguridad.
                        Mantén el control total de tu cuenta en todo momento.
                    </p>
                </div>

                <div class="col-12 col-lg-6 text-center">
                    <i class="fa-solid fa-user-shield text-primary" style="font-size: 5rem;"></i>
                </div>

            </div>
        </div>
    </section>

    <!-- INFORMACIÓN PERSONAL -->
    <section class="py-5">
        <div class="container">

            <h4 class="fw-bold mb-4">Información personal</h4>

            <div class="card border-0 shadow-sm p-4">
                <form>
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Nombres">
                                <label>Nombres</label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Apellidos">
                                <label>Apellidos</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" placeholder="correo@ejemplo.com">
                        <label>Correo electrónico</label>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Guardar cambios
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </section>

    <!-- SEGURIDAD -->
    <section class="py-5 bg-light">
        <div class="container">

            <h4 class="fw-bold mb-4">Seguridad</h4>

            <div class="row g-4">

                <!-- Cambiar contraseña -->
                <div class="col-12 col-lg-6">
                    <div class="card border-0 shadow-sm p-4 h-100">

                        <i class="fa-solid fa-lock text-primary fs-3 mb-3"></i>

                        <h5 class="fw-semibold">Contraseña</h5>

                        <p class="text-muted small">
                            Actualiza tu contraseña periódicamente para proteger tu cuenta.
                        </p>

                        <a asp-controller="Auth" asp-action="ResetPassword" class="btn btn-outline-primary mt-auto">
                            Cambiar contraseña
                        </a>

                    </div>
                </div>

                <!-- MFA DESTACADO -->
                <div class="col-12 col-lg-6">
                    <div class="card border-0 shadow-sm p-4 h-100 border border-success">

                        <i class="fa-solid fa-shield-halved text-success fs-3 mb-3"></i>

                        <h5 class="fw-semibold">Autenticación en dos factores</h5>

                        <p class="text-muted small">
                            Añade una capa extra de seguridad a tu cuenta mediante verificación en dos pasos.
                        </p>

                        <button class="btn btn-success mt-auto"
                                data-bs-toggle="modal"
                                data-bs-target="#mfaModal">
                            <i class="fa-solid fa-shield me-2"></i>Activar seguridad
                        </button>

                    </div>
                </div>

            </div>

        </div>
    </section>

    <!-- PREFERENCIAS -->
    <section class="py-5">
        <div class="container">

            <h4 class="fw-bold mb-4">Preferencias</h4>

            <div class="card border-0 shadow-sm p-4">

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="emailNotifications">
                    <label class="form-check-label">
                        Notificaciones por correo
                    </label>
                </div>

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="loginAlerts">
                    <label class="form-check-label">
                        Alertas de inicio de sesión
                    </label>
                </div>

                <div class="form-floating mb-3">
                    <select class="form-select">
                        <option selected>USD</option>
                        <option>EUR</option>
                        <option>BTC</option>
                    </select>
                    <label>Moneda preferida</label>
                </div>

                <button class="btn btn-warning text-white">
                    Guardar preferencias
                </button>

            </div>

        </div>
    </section>

    <!-- ZONA DE RIESGO -->
    <section class="py-5 bg-light">
        <div class="container">

            <h4 class="fw-bold text-danger mb-4">Zona de riesgo</h4>

            <div class="card border-danger border p-4 shadow-sm">

                <p class="text-muted small">
                    Estas acciones son irreversibles. Procede con precaución.
                </p>

                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-danger">
                        <i class="fa-solid fa-ban me-2"></i>Bloquear cuenta
                    </button>

                    <button class="btn btn-danger">
                        <i class="fa-solid fa-trash me-2"></i>Eliminar cuenta
                    </button>
                </div>

            </div>

        </div>
    </section>

</main>

<!-- MODAL MFA -->
<div class="modal fade" id="mfaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">
                    <i class="fa-solid fa-shield-halved text-success me-2"></i>
                    Activar autenticación en dos factores
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="activateMfaForm">
                @Html.AntiForgeryToken()
                <div class="modal-body text-center">

                    <p class="text-muted mb-3">
                        Escanea este código QR con tu aplicación de autenticación (Google Authenticator, Authy, etc.)
                    </p>

                    <div class="text-center mb-4 p-3 border rounded-3 bg-light d-inline-block">
                        <img src="@ViewBag.BarcodeImageUrl" alt="Código QR de Seguridad" class="img-fluid" />
                    </div>

                    <p class="small text-muted mb-3">
                        Una vez escaneado, ingresa el código generado para completar la activación.
                    </p>

                    <div class="form-floating px-4">
                        <input type="text" class="form-control text-center fs-4 fw-bold tracking-widest"
                               id="mfaCode" name="Code" placeholder="000000" maxlength="6" required autocomplete="off">
                        <label for="mfaCode" class="text-muted">Código de 6 dígitos</label>
                    </div>

                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-success" id="btnConfirmMfa">
                        <i class="fa-solid fa-check me-2"></i>Confirmar activación
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/ajax/user-ajax-scripts.js" asp-append-version="true"></script>
}

@section Styles
{
    
}