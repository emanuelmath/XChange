<!DOCTYPE html>

<html lang="es" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/fontawesome/css/all.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/toast-style.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary navbar-fintech py-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center fw-bold fs-4" asp-controller="User" asp-action="Dashboard">
                    <img src="~/images/logo.svg" alt="XChange Logo" height="32" class="me-2">
                    <span style="letter-spacing: 0.05em;">XChange</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPrivate">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarPrivate">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-1">
                        <li class="nav-item">
                            <a class="nav-link rounded px-3 d-flex align-items-center @(currentAction == "Dashboard" ? "active bg-white bg-opacity-10" : "")"
                                   asp-controller="User" asp-action="Dashboard">
                                <i class="fa-solid fa-chart-line me-2"></i>Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link rounded px-3 d-flex align-items-center @(currentAction == "Wallet" ? "active bg-white bg-opacity-10" : "")"
                                   asp-controller="User" asp-action="Wallet">
                                <i class="fa-solid fa-wallet me-2"></i>Billetera
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link rounded px-3 d-flex align-items-center @(currentAction == "Transactions" ? "active bg-white bg-opacity-10" : "")"
                                   asp-controller="User" asp-action="Transactions">
                                <i class="fa-solid fa-right-left me-2"></i>Movimientos
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center rounded-pill px-3 profile-pill text-white"
                                   href="#" role="button" data-bs-toggle="dropdown">
                                <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
                                    <i class="fa-solid fa-user small"></i>
                                </div>
                                <span class="fw-semibold">Mi Cuenta</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 rounded-3">
                                <li>
                                    <a class="dropdown-item py-2" asp-controller="User" asp-action="Settings">
                                        <i class="fa-solid fa-gear me-2 text-muted"></i>Configuración
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item py-2 text-danger" asp-controller="Auth" asp-action="Logout">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div>
        @RenderBody()
    </div>

        <!-- Pie de página del Layout -->
        <footer class="bg-light border-top mt-auto">
            <div class="container py-5">

                <div class="row">

                    <!-- Marca -->
                    <div class="col-12 col-md-4 mb-4">
                        <h5 class="fw-bold d-flex align-items-center">
                            <img src="~/images/logo.svg" alt="XChange Logo" class="me-2" height="28">
                                XChange
                            </h5>
                            <p class="text-muted small">
                                Plataforma de billetera digital enfocada en seguridad, rapidez y confianza para tus transacciones.
                            </p>
                        </div>

                        <!-- Navegación -->
                        <div class="col-6 col-md-2 mb-4">
                            <h6 class="fw-semibold">Navegación</h6>
                            <ul class="list-unstyled">
                                <li><a asp-controller="Home" asp-action="Landing" class="text-decoration-none text-muted">Inicio</a></li>
                                <li><a asp-controller="Home" asp-action="About" class="text-decoration-none text-muted">Acerca de</a></li>
                                <li><a asp-controller="Home" asp-action="Contact" class="text-decoration-none text-muted">Contacto</a></li>
                            </ul>
                        </div>

                        <!-- Legal -->
                        <div class="col-6 col-md-3 mb-4">
                            <h6 class="fw-semibold">Legal</h6>
                            <ul class="list-unstyled">
                                <li><a asp-action="Terms" asp-controller="Home" class="text-decoration-none text-muted" target="_blank">Términos y condiciones</a></li>
                            </ul>
                        </div>

                        <!-- Redes -->
                        <div class="col-12 col-md-3 mb-4">
                            <h6 class="fw-semibold">Síguenos</h6>

                            <div class="d-flex gap-3">
                                <a href="#" class="text-muted fs-5">
                                    <i class="fa-brands fa-facebook"></i>
                                </a>
                                <a href="#" class="text-muted fs-5">
                                    <i class="fa-brands fa-twitter"></i>
                                </a>
                                <a href="#" class="text-muted fs-5">
                                    <i class="fa-brands fa-instagram"></i>
                                </a>
                                <a href="#" class="text-muted fs-5">
                                    <i class="fa-brands fa-linkedin"></i>
                                </a>
                            </div>

                        </div>

                    </div>

                    <!-- Línea inferior -->
                    <div class="border-top pt-3 mt-3 text-center">
                        <small class="text-muted">
                            &copy; @DateTime.Now.Year XChange. Todos los derechos reservados.
                        </small>
                    </div>

                </div>
            </footer>

    <!-- Scripts -->
    <script src="~/js/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/toast-script.js"></script>
    <script src="~/js/ajax-scripts.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
