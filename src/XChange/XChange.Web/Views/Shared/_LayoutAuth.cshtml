<!DOCTYPE html>

<html lang="es" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/fontawesome/css/all.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/toast-style.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Sección de encabezado del módulo Auth -->
    <header class="bg-white shadow-sm py-3">
        <div class="container d-flex justify-content-between align-items-center">
            <h1 class="h4 mb-0 fw-bolder text-primary tracking-tight">XChange</h1>
        </div>
    </header>

    <!-- Contenido dinámico del módulo Auth -->
    <div>
        @RenderBody()
    </div>

    <!-- Sección de pie de página del módulo Auth -->
    <footer class="bg-white border-top py-4 mt-auto">
        <div class="container text-center">
            <small class="text-muted fw-medium">&copy; @DateTime.Now.Year XChange. Todos los derechos reservados.</small>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/js/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/toast-script.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
